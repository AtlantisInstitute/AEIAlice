# Alice Notification Service - Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# --- Discord ---
# Bot token (retained for reference; Alice posts via webhooks, not the gateway)
DISCORD_TOKEN=your-discord-bot-token

# Channel IDs (right-click channel in Discord with Developer Mode enabled)
DISCORD_CHANNEL_GENERAL=123456789012345678
DISCORD_CHANNEL_JIRA=123456789012345678
DISCORD_CHANNEL_GITHUB=123456789012345678
DISCORD_CHANNEL_COMMITS=123456789012345678

# Webhook URLs (Server Settings > Integrations > Webhooks)
DISCORD_WEBHOOK_GENERAL=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_JIRA=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_GITHUB=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_COMMITS=https://discord.com/api/webhooks/...

# --- Jira ---
JIRA_SERVER=https://your-company.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=AEI
JIRA_WEBHOOK_SECRET=

# --- GitHub ---
GITHUB_TOKEN=your-github-personal-access-token
# Comma-separated list of repos to monitor
GITHUB_REPOS=YourOrg/YourRepo
GITHUB_WEBHOOK_SECRET=

# --- Confluence ---
CONFLUENCE_SERVER=https://your-company.atlassian.net/wiki
CONFLUENCE_WEBHOOK_SECRET=

# --- Webhook Server ---
WEBHOOK_PORT=8080
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PATH=/webhooks

# --- Polling ---
# GitHub commit polling interval in seconds (default: 60)
GITHUB_POLL_INTERVAL=60
